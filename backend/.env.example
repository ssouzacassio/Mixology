# Copie para .env e preencha
# String de conexão do Postgres (Railway fornece isso ao criar o banco)
URL_BANCO_DADOS=postgres://usuario:senha@host:5432/nome_do_banco

# Qualquer texto longo e aleatório, usado para assinar os tokens de login
SEGREDO_JWT=troque-por-um-valor-secreto-longo

PORTA=8080
ORIGEM_PERMITIDA=http://localhost:3000
